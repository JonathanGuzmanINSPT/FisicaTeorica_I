---
import BaseLayout from './BaseLayout.astro';
import type { Unidad } from '../data/unidades';

export interface Props {
  title: string;
  unidad: Unidad;
  currentSlug?: string;
}

const { title, unidad, currentSlug } = Astro.props;
const BASE = import.meta.env.BASE_URL || '/';
---

<BaseLayout title={title}>
  <div class="unidad-header">
    <div class="unidad-badge" data-estado={unidad.estado}>
      <span class="badge-icon">{unidad.icono}</span>
      <span class="badge-text">Unidad {unidad.numero}</span>
    </div>
    <h1 class="unidad-title">{unidad.titulo}</h1>
    <p class="unidad-desc">{unidad.descripcion}</p>
  </div>

  <nav class="unidad-nav">
    {unidad.archivos.map(archivo => (
      <a
        href={BASE + unidad.id + '/' + archivo.slug + '/'}
        class={`unidad-nav-link ${currentSlug === archivo.slug ? 'active' : ''}`}
        data-tipo={archivo.tipo}
      >
        {archivo.titulo}
      </a>
    ))}
  </nav>

  <article class="prose">
    <slot />
  </article>
</BaseLayout>

<style>
  .unidad-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-primary);
  }

  .unidad-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.8rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .unidad-badge[data-estado="completado"] {
    background: var(--green-bg);
    color: var(--green);
    border: 1px solid rgba(74, 222, 128, 0.2);
  }

  .unidad-badge[data-estado="en-curso"] {
    background: var(--blue-bg);
    color: var(--blue);
    border: 1px solid rgba(96, 165, 250, 0.2);
  }

  .unidad-badge[data-estado="pendiente"] {
    background: var(--amber-bg);
    color: var(--amber);
    border: 1px solid rgba(251, 191, 36, 0.2);
  }

  .badge-icon { font-size: 0.9rem; }
  .badge-text { text-transform: uppercase; letter-spacing: 0.08em; }

  .unidad-title {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .unidad-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    max-width: 600px;
  }

  .unidad-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-primary);
  }

  .unidad-nav-link {
    padding: 0.45rem 1rem;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    background: var(--bg-tertiary);
    color: var(--text-secondary);
    border: 1px solid var(--border-primary);
    transition: all var(--transition-fast);
  }

  .unidad-nav-link:hover {
    border-color: var(--border-accent);
    color: var(--text-primary);
    background: var(--accent-muted);
  }

  .unidad-nav-link.active {
    background: var(--accent-muted);
    border-color: var(--accent);
    color: var(--accent);
  }

  .prose h2 { margin-top: 2.5rem; }
  .prose h3 { margin-top: 2rem; }
  .prose img { max-width: 100%; border-radius: var(--radius-md); }
</style>
