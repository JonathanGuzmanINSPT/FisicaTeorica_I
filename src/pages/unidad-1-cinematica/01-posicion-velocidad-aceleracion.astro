---
import UnidadLayout from '../../layouts/UnidadLayout.astro';
import { unidades } from '../../data/unidades';
import '../../styles/global.css';

const unidad = unidades.find(u => u.id === 'unidad-1-cinematica')!;
const archivo = unidad.archivos[0];
---

<UnidadLayout title="Cinemática — Unidad 1" unidad={unidad} currentSlug="01-posicion-velocidad-aceleracion">
  <article class="prose">
    <h1>📐 Cinemática de puntos materiales</h1>
    <p class="subtitle">Posición, velocidad y aceleración. Movimiento rectilíneo y curvilíneo.</p>
    
    <div class="content-placeholder">
      <p>El contenido completo se está migrando. Por ahora podés ver el markdown original en el repositorio:</p>
      <a href="https://github.com/neonplus/fisica-teorica-i-2026/blob/main/unidad-1-cinematica/01-posicion-velocidad-aceleracion.md" target="_blank" class="github-link">
        Ver en GitHub →
      </a>
    </div>
  </article>
</UnidadLayout>

<style>
  .subtitle { color: var(--text-secondary); margin-bottom: 2rem; }
  .content-placeholder { 
    padding: 2rem; 
    background: var(--bg-secondary); 
    border-radius: var(--radius-md); 
    border: 1px solid var(--border-primary);
    text-align: center;
  }
  .github-link {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.5rem 1.2rem;
    background: var(--accent-muted);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-sm);
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }
  .github-link:hover { background: var(--accent-glow); }
</style>
