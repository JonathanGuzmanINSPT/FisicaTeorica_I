---
import Layout from '../../layouts/BaseLayout.astro';
import Content from '../../../unidad-1-cinematica/01-ejercicios-posicion-velocidad-aceleracion.md';
---

<Layout title="Ejercicios - Posición, Velocidad y Aceleración">
  <div class="markdown-content">
    <Content />
  </div>
</Layout>

<style>
  .markdown-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    line-height: 1.8;
  }
  
  .markdown-content h1, .markdown-content h2, .markdown-content h3 {
    color: var(--color-primary);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .markdown-content p {
    margin-bottom: 1rem;
  }
  
  .markdown-content code {
    background: var(--color-bg-secondary);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-family: 'Fira Code', monospace;
  }
  
  .markdown-content pre {
    background: var(--color-bg-secondary);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
  }
</style>
